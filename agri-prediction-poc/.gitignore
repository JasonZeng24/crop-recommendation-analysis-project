# ==========================================
# Python Bytecode & Cache
# ==========================================
# Ignore folders generated by the Python interpreter
__pycache__/
# Ignore compiled Python files (bytecode)
*.py[cod]

# ==========================================
# Jupyter Notebook Metadata
# ==========================================
# Ignore temporary checkpoints created by Jupyter
.ipynb_checkpoints

# ==========================================
# Virtual Environments (Crucial!)
# ==========================================
# Do not track local environment dependencies and interpreters
venv/
env/
.env

# ==========================================
# OS-Specific Files
# ==========================================
# Ignore macOS-specific folder metadata files
.DS_Store